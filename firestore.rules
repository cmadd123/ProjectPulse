rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isContractor() {
      return isAuthenticated() && getUserRole() == 'contractor';
    }

    function isClient() {
      return isAuthenticated() && getUserRole() == 'client';
    }

    function isTeamMemberRole() {
      return isAuthenticated() && getUserRole() == 'team_member';
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.contractor_ref ==
        /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isProjectCollaborator(projectId) {
      return false; // Placeholder - actual check happens in write rules with exists() check
    }

    function isProjectClient(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAuthenticated() && (
        project.client_user_ref == /databases/$(database)/documents/users/$(request.auth.uid) ||
        project.client_email == request.auth.token.email
      );
    }

    function isTeamMemberForProject(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isTeamMemberRole() && request.auth.uid in project.assigned_member_uids;
    }

    function isForemanForProject(projectId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAuthenticated() &&
        userData.role == 'team_member' &&
        userData.team_member_profile.team_role == 'foreman' &&
        userData.team_id == project.team_id;
    }

    function canAccessProject(projectId) {
      return isProjectOwner(projectId) || isProjectClient(projectId) || isTeamMemberForProject(projectId) || isForemanForProject(projectId);
    }

    function isTeamOwner(teamId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.owner_uid == request.auth.uid;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.member_uids;
    }

    // Teams collection
    match /teams/{teamId} {
      // Team owner can read and update their team
      allow read, update: if isTeamOwner(teamId);

      // Team members can read their team doc (to get team name)
      allow read: if isTeamMember(teamId);

      // Authenticated users can create teams (happens during contractor signup before user doc exists)
      allow create: if isAuthenticated() &&
        request.resource.data.owner_uid == request.auth.uid;

      // Allow invited members to add themselves to member_uids during signup
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_uids']);

      // Only owner can delete team
      allow delete: if isTeamOwner(teamId);

      // Team members subcollection
      match /members/{memberId} {
        // Team owner can manage members
        allow read, write: if isTeamOwner(teamId);

        // Team members can read all members in their team
        allow read: if isTeamMember(teamId);

        // Allow users to read their own invite by email (for email-based auto-linking on signup)
        allow read: if isAuthenticated() &&
          resource.data.email == request.auth.token.email;

        // Allow anyone authenticated to update their own member doc (for invite acceptance)
        allow update: if isAuthenticated() &&
          request.resource.data.user_uid == request.auth.uid;
      }

      // Subcontractors subcollection
      match /subcontractors/{subId} {
        // Team owner can CRUD subcontractors
        allow read, write: if isTeamOwner(teamId);

        // Team members can read subcontractors
        allow read: if isTeamMember(teamId);

        // COI subcollection
        match /coi/{coiId} {
          // Team owner can CRUD COIs
          allow read, write: if isTeamOwner(teamId);

          // Team members can read COIs
          allow read: if isTeamMember(teamId);
        }
      }

      // Schedule entries subcollection (weekly crew scheduling)
      match /schedule_entries/{entryId} {
        // Team owner can CRUD schedule entries
        allow read, write: if isTeamOwner(teamId);

        // Foremen can read and write schedule entries
        allow read, write: if isTeamMember(teamId) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_member_profile.team_role == 'foreman';

        // Team members can read schedule entries (see their own schedule)
        allow read: if isTeamMember(teamId);
      }
    }

    // Pending team invites (email-based lookup for auto-linking on signup)
    match /pending_team_invites/{email} {
      // Contractors can create, read, and write invites when managing team members
      allow read, create, write: if isContractor();

      // Workers can read their own invite (email matches their auth email)
      allow read: if isAuthenticated() && email == request.auth.token.email;

      // Workers can delete their invite after linking (cleanup)
      allow delete: if isAuthenticated() && email == request.auth.token.email;
    }

    // Pending subcontractor invites (email-based lookup for auto-linking on signup)
    match /pending_sub_invites/{email} {
      allow create, write: if isContractor();
      allow read: if isAuthenticated() && email == request.auth.token.email;
      allow delete: if isAuthenticated() && email == request.auth.token.email;
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // Anyone authenticated can create their initial profile
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Team owner (GC) can update team member's role
      allow update: if isAuthenticated() &&
        resource.data.role == 'team_member' &&
        resource.data.team_id != null &&
        isTeamOwner(resource.data.team_id) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['team_member_profile']);

      // Team owner can read team members' profiles (to verify linking)
      allow read: if isAuthenticated() &&
        resource.data.role == 'team_member' &&
        resource.data.team_id != null &&
        isTeamOwner(resource.data.team_id);
    }

    // Projects collection
    match /projects/{projectId} {
      // Contractors can create projects
      allow create: if isContractor() &&
        request.resource.data.contractor_ref == /databases/$(database)/documents/users/$(request.auth.uid);

      // Project owner, team members, and client can read individual documents
      allow get: if canAccessProject(projectId);

      // Public single-doc read for the client-facing project view (Fork 3).
      // Set is_shared=true by Cloud Function on conversion; project IDs are
      // 20-char Firestore random tokens, so the URL is the bearer token.
      allow get: if resource.data.is_shared == true;

      // Allow contractors and team members to list projects
      // Allow clients to list projects where they are the client
      allow list: if isAuthenticated();

      // Only project owner can update project (add collaborators, change status, etc.)
      allow update: if isProjectOwner(projectId) ||
        // Allow client to link themselves to project if email matches
        (isAuthenticated() &&
         request.resource.data.client_email == request.auth.token.email &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['client_user_ref'])) ||
        // Allow client to update project cost (after approving change order)
        (isProjectClient(projectId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['current_cost'])) ||
        // Allow team members and foremen to update project timestamp
        ((isTeamMemberForProject(projectId) || isForemanForProject(projectId)) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updated_at'])) ||
        // Allow adding to assigned_member_uids (during team member auto-link on signup)
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assigned_member_uids']));

      // Only project owner can delete
      allow delete: if isProjectOwner(projectId);

      // Milestones subcollection
      match /milestones/{milestoneId} {
        // Owner can create/read/update/delete milestones
        allow write: if isProjectOwner(projectId);

        // Client can update milestones (approve, request changes)
        allow update: if isProjectClient(projectId);

        // Foreman can update milestone status (start/complete)
        allow update: if isForemanForProject(projectId);

        // Anyone authenticated can read milestones
        allow read: if isAuthenticated();

        // Public single-doc + list read when parent project is shared (Fork 3
        // client view). Look up parent and check its is_shared flag.
        allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true;

        // Public milestone approval (Fork 3). Allows unauthenticated update
        // when the parent project is shared, current status is
        // "awaiting_approval", and only the approval-related fields change.
        // Locks down everything else so a malicious actor with the URL can't
        // rewrite amount, percentage, etc.
        allow update: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true
          && resource.data.status == 'awaiting_approval'
          && request.resource.data.status == 'approved'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly([
                 'status',
                 'approved_at',
                 'approved_by_name',
                 'approved_signature_text',
                 'approved_user_agent'
               ]);

        // Change requests subcollection (client feedback on milestones)
        match /change_requests/{requestId} {
          // Client can create change requests
          allow create: if isProjectClient(projectId);

          // Owner and client can read
          allow read: if isProjectOwner(projectId) || isProjectClient(projectId);

          // Owner can update (mark as addressed)
          allow update: if isProjectOwner(projectId);
        }
      }

      // Updates (photo posts) subcollection
      match /updates/{updateId} {
        // Owner and team members can create updates
        allow create: if isAuthenticated() && (
          // Ensure posted_by_ref matches current user
          request.resource.data.posted_by_ref == /databases/$(database)/documents/users/$(request.auth.uid)
        );

        // Anyone authenticated can read updates
        allow read: if isAuthenticated();

        // Only the person who posted can update/delete their own update
        allow update, delete: if isAuthenticated() &&
          resource.data.posted_by_ref == /databases/$(database)/documents/users/$(request.auth.uid);

        // Public read for the Fork 3 client project view — gated by parent
        // project's is_shared flag (mirrors milestones / invoices pattern).
        allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true;
      }

      // Change orders subcollection
      match /change_orders/{orderId} {
        // Owner can create change orders
        allow create: if isProjectOwner(projectId);

        // Anyone authenticated can read change orders
        allow read: if isAuthenticated();

        // Owner can update (modify details before client approves)
        // Client can update (approve/decline)
        allow update: if isProjectOwner(projectId) || isProjectClient(projectId);

        // Only owner can delete
        allow delete: if isProjectOwner(projectId);

        // Public read + approval (Fork 3). Gated by parent project's is_shared.
        // Approval is locked to the pending→approved|declined transition and
        // the signature fields — nothing else can be touched.
        allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true;
        allow update: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true
          && resource.data.status == 'pending'
          && (request.resource.data.status == 'approved'
              || request.resource.data.status == 'declined')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly([
                 'status',
                 'responded_at',
                 'approved_by_name',
                 'approved_signature_text',
                 'approved_user_agent',
                 'decline_reason'
               ]);
      }

      // Messages subcollection (future feature)
      match /messages/{messageId} {
        // Owner and client can create messages
        allow create: if isAuthenticated() && (
          isProjectOwner(projectId) ||
          isProjectClient(projectId)
        );

        // Everyone with project access can read
        allow read: if canAccessProject(projectId);

        // Can't update messages (audit trail), owner can delete (project cleanup)
        allow update: if false;
        allow delete: if isProjectOwner(projectId);
      }

      // Expenses subcollection (materials & job costing)
      match /expenses/{expenseId} {
        // Owner, client, and team members can read expenses
        allow read: if canAccessProject(projectId);

        // Owner and foremen can create expenses
        allow create: if isProjectOwner(projectId) || isForemanForProject(projectId);

        // Only owner can update or delete expenses (correct mistakes)
        allow update, delete: if isProjectOwner(projectId);
      }

      // Documents subcollection (document vault + lien waivers)
      match /documents/{docId} {
        // Owner can CRUD documents
        allow read, write: if isProjectOwner(projectId);

        // Client and team members can read documents
        allow read: if canAccessProject(projectId);

        // Foreman can create documents (upload from job site)
        allow create: if isForemanForProject(projectId);
      }

      // Time entries subcollection (hours logging per project)
      match /time_entries/{entryId} {
        // All project participants can read time entries
        allow read: if canAccessProject(projectId);

        // Owner can create time entries for anyone
        allow create: if isProjectOwner(projectId);

        // Foreman can create time entries for anyone on project
        allow create: if isForemanForProject(projectId);

        // Team members can create their own time entries only
        allow create: if isTeamMemberForProject(projectId) &&
          request.resource.data.logged_by_uid == request.auth.uid;

        // Owner can update or delete any time entry
        allow update, delete: if isProjectOwner(projectId);

        // Creator can update their own entry
        allow update: if isAuthenticated() &&
          resource.data.logged_by_uid == request.auth.uid;
      }

      // Client changes subcollection (quality issues + addition requests)
      match /client_changes/{changeId} {
        // Everyone with project access can read
        allow read: if canAccessProject(projectId);

        // Client creates these; contractor allowed too for demo seeding
        allow create: if canAccessProject(projectId);

        // Owner can mark as addressed, client can update their own status
        allow update: if isProjectOwner(projectId) || isProjectClient(projectId);

        // Only owner can delete (cleanup)
        allow delete: if isProjectOwner(projectId);
      }

      // Invoices subcollection (generated after milestone approval)
      match /invoices/{invoiceId} {
        // Owner and client can read invoices
        allow read: if canAccessProject(projectId);

        // Owner and client can create invoices (client triggers via milestone approval)
        allow create: if isProjectOwner(projectId) || isProjectClient(projectId);

        // Owner can update (mark as paid) and delete
        allow update, delete: if isProjectOwner(projectId);

        // Public single-doc read for the Fork 3 invoice payment page. Inherits
        // shareability from the parent project (don't need a per-invoice flag).
        // Stripe webhook updates go through Admin SDK so they bypass rules.
        allow get: if get(/databases/$(database)/documents/projects/$(projectId)).data.is_shared == true;
      }
    }

    // Estimates collection (pre-sale quoting)
    match /estimates/{estimateId} {
      // Contractor can CRUD their own estimates
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() &&
        resource.data.contractor_uid == request.auth.uid;
      // Allow listing by contractor_uid
      allow list: if isAuthenticated();
    }

    // Per-team settings (pulse-web): Stripe Connect account, default
    // deposit %, letterhead overrides. Doc ID is the team_id itself.
    //
    // Team members can read + initialize. The Stripe account fields
    // (stripe_account_id, stripe_account_status, stripe_connected_at) are
    // written ONLY from the Vercel API route using Firebase Admin SDK, which
    // bypasses these rules — so they can't be tampered with from a browser
    // session. Client-side updates from team members are restricted to the
    // non-sensitive fields (default_deposit_percent, etc).
    match /org_settings/{teamId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id == teamId;

      // First-time create — only the team member can seed.
      allow create: if isAuthenticated()
        && request.resource.data.team_id == teamId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id == teamId
        && !('stripe_account_id' in request.resource.data);

      // Client-side updates restricted to safe fields. Stripe linkage fields
      // are admin-only.
      allow update: if isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id == teamId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['default_deposit_percent', 'updated_at']);
    }

    // Customers collection (pulse-web: bid → project → invoice spine)
    // Scoped to team_id; any team member can CRUD their team's customers.
    match /customers/{customerId} {
      allow create: if isAuthenticated()
        && request.resource.data.team_id ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id;
      allow read, update, delete: if isAuthenticated()
        && resource.data.team_id ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id;
      allow list: if isAuthenticated();
    }

    // Bids collection (pulse-web: pre-acceptance proposals on a customer)
    // Same team scoping as customers. Line items live in a subcollection.
    // Public single-doc read allowed when is_shared == true (homeowner link).
    match /bids/{bidId} {
      allow create: if isAuthenticated()
        && request.resource.data.team_id ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id;
      allow read, update, delete: if isAuthenticated()
        && resource.data.team_id ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id;
      allow list: if isAuthenticated();

      // Public single-doc read for the customer-facing share link.
      // Bid IDs are random 20-char strings (~120 bits), so the URL itself
      // is the bearer token; flipping is_shared off revokes access.
      allow get: if resource.data.is_shared == true;

      // Public accept / decline. Only allowed when the bid is currently
      // shared and in "sent" state, and only the status + the matching
      // timestamp / signature fields may change. Locks down everything else
      // (line items, totals, scope, contractor info, etc) so a malicious
      // actor with the URL can't rewrite the bid.
      allow update: if resource.data.is_shared == true
        && resource.data.status == 'sent'
        && (request.resource.data.status == 'accepted'
            || request.resource.data.status == 'declined')
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'status',
               'accepted_at',
               'declined_at',
               'accepted_by_name',
               'accepted_signature_text',
               'accepted_user_agent'
             ]);

      // Public view tracking. Anyone with the URL can bump the view counters
      // — same trust model as the read. Locked to the three view fields so
      // it can't be used to mutate the bid.
      allow update: if resource.data.is_shared == true
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['view_count', 'first_viewed_at', 'last_viewed_at']);

      match /lineItems/{lineItemId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/bids/$(bidId)).data.team_id ==
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.team_id;
      }
    }

    // Notifications collection (for push notification queue)
    match /notifications/{notificationId} {
      // Cloud Functions create notifications
      allow create: if isAuthenticated();

      // Recipients can read their own notifications
      allow read: if isAuthenticated() &&
        resource.data.recipient_ref == /databases/$(database)/documents/users/$(request.auth.uid);

      // Recipients can mark their own notifications as read
      allow update: if isAuthenticated() &&
        resource.data.recipient_ref == /databases/$(database)/documents/users/$(request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Auto-delete old notifications
      allow delete: if false; // Only Cloud Functions
    }

    // Reviews subcollection (under contractors)
    match /contractors/{contractorId}/reviews/{reviewId} {
      // Clients can create reviews for projects they were part of
      allow create: if isClient();

      // Everyone can read reviews (public)
      allow read: if true;

      // Can't update or delete reviews (permanent record)
      allow update, delete: if false;
    }
  }
}
